# =============================================================================
# Slack Kudos Digest — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
# =============================================================================

# ─── Required ────────────────────────────────────────────────────────────────
#
# Where to find these in the Slack API dashboard (https://api.slack.com/apps):
#
#   1. Go to https://api.slack.com/apps
#   2. Click on your "Kudos Digest" app
#
# SLACK_BOT_TOKEN:
#   Settings → Install App → "Bot User OAuth Token" (starts with xoxb-)
#   This is generated when you click "Install to Workspace"
#
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# SLACK_SIGNING_SECRET:
#   Settings → Basic Information → "Signing Secret"
#   Copy the string under "App Credentials"
#
SLACK_SIGNING_SECRET=your-signing-secret-here

# ─── Required for Socket Mode (recommended) ──────────────────────────────────
#
# SLACK_APP_TOKEN:
#   Settings → Socket Mode → Enable Socket Mode → Generate an app-level token
#   Scopes needed: connections:write
#   Starts with xapp-
#
#   Without this, the app runs in HTTP mode and needs a public URL.
#   With it, the app connects via WebSocket — no public URL needed.
#
SLACK_APP_TOKEN=xapp-your-app-token-here

# ─── Optional ────────────────────────────────────────────────────────────────

# Port for the HTTP server (only used if SLACK_APP_TOKEN is NOT set)
PORT=3000

# Path to the SQLite database file
DATABASE_PATH=./kudos.db

# ─── Notes ───────────────────────────────────────────────────────────────────
#
# AI API keys (OpenAI, Anthropic) are NOT stored here.
# They are configured per-workspace via the App Home → Settings page.
# This keeps them secure and allows each workspace to use their own key.
#