# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here # Optional: for Socket Mode

# Server Configuration
PORT=3000

# Database Path (optional, defaults to ./kudos.db)
DATABASE_PATH=./kudos.db

# Note: AI API keys are stored per-workspace in the app settings
# Users can configure their own AI provider via the Settings page